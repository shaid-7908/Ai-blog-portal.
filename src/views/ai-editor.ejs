    <%- include('components/commonscript') %>

        <script>
            $(document).ready(function () {
                // ── Word Count Range Slider ──
                const slider = $('#word-count-slider');
                const display = $('#word-count-value');

                slider.on('input', function () {
                    const val = parseInt($(this).val());
                    const minRange = Math.max(500, val - 500);
                    const maxRange = val + 500;
                    display.text(minRange + ' - ' + maxRange);
                });
                // Initial call to set range based on initial slider value (1500 -> 1000 - 2000)
                slider.trigger('input');

                // ── Writing Tone Selection ──
                $('.tone-btn').on('click', function () {
                    $('.tone-btn').removeClass('active');
                    $(this).addClass('active');
                    $('#writing-tone-hidden').val($(this).data('tone'));
                });

                // ── Keywords Tag Input ──
                const tagInputContainer = $('#keyword-tags-container');
                const keywordInput = $('#keyword-input');
                const keywordChips = $('#keyword-chips');
                const keywordsHidden = $('#keywords-hidden');

                // Array to store current tags
                let tags = ['React', 'Microservices', 'WASM'];

                function renderTags() {
                    keywordChips.empty();
                    tags.forEach(function (tag) {
                        keywordChips.append(`
                        <span class="tag-chip">
                            ${tag}
                            <a href="#" class="remove-tag" data-tag="${tag}">&times;</a>
                        </span>
                    `);
                    });
                    keywordsHidden.val(tags.join(','));
                }

                // Focus input when container is clicked
                tagInputContainer.on('click', function (e) {
                    if (e.target !== keywordInput[0]) {
                        keywordInput.focus();
                    }
                });

                // Add tag on Enter or Comma
                keywordInput.on('keydown', function (e) {
                    if (e.key === 'Enter' || e.key === ',') {
                        e.preventDefault();
                        let tag = keywordInput.val().trim().replace(/,/g, '');
                        if (tag && !tags.includes(tag)) {
                            tags.push(tag);
                            renderTags();
                            keywordInput.val('');
                        }
                    } else if (e.key === 'Backspace' && keywordInput.val() === '' && tags.length > 0) {
                        tags.pop();
                        renderTags();
                    }
                });

                // Remove tag
                keywordChips.on('click', '.remove-tag', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const tagToRemove = $(this).data('tag');
                    tags = tags.filter(t => t !== tagToRemove);
                    renderTags();
                });

                // ── Dynamic Category Population & Multi-Select ──
                let allCategories = [
                    { _id: 'technology', name: 'Technology', slug: 'technology' },
                    { _id: 'business', name: 'Business', slug: 'business' },
                    { _id: 'finance', name: 'Finance', slug: 'finance' },
                    { _id: 'lifestyle', name: 'Lifestyle', slug: 'lifestyle' },
                    { _id: 'health', name: 'Health & Wellness', slug: 'health' }
                ];
                let selectedCategories = [];

                function renderCategorySelect() {
                    const select = $('#category-select');
                    select.empty();
                    select.append('<option value="" disabled selected>Select category...</option>');

                    allCategories.forEach(function (cat) {
                        if (!selectedCategories.some(c => c._id === cat._id)) {
                            select.append(`<option value="${cat._id}">${cat.name}</option>`);
                        }
                    });
                }

                function renderCategories() {
                    const chipsContainer = $('#category-chips');
                    chipsContainer.empty();

                    selectedCategories.forEach(function (cat) {
                        chipsContainer.append(`
                        <span class="tag-chip">
                            ${cat.name}
                            <a href="#" class="remove-category" data-id="${cat._id}">&times;</a>
                        </span>
                    `);
                    });

                    $('#categories-hidden').val(selectedCategories.map(c => c._id).join(','));
                    renderCategorySelect();
                }

                $('#category-select').on('change', function () {
                    const selectedVal = $(this).val();
                    if (!selectedVal) return;

                    const catObj = allCategories.find(c => c._id === selectedVal);
                    if (catObj && !selectedCategories.some(c => c._id === selectedVal)) {
                        selectedCategories.push(catObj);
                        renderCategories();
                    }

                    $(this).val('');
                });

                $('#category-chips').on('click', '.remove-category', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const idToRemove = $(this).data('id');
                    selectedCategories = selectedCategories.filter(c => c._id !== idToRemove);
                    renderCategories();
                });

                $.ajax({
                    url: '/api/v1/blog-category/get-all?limit=100&isActive=true',
                    method: 'GET',
                    success: function (res) {
                        if (res.success && res.data && res.data.docs && res.data.docs.length > 0) {
                            allCategories = res.data.docs;
                        }

                        const defaultCat = allCategories.find(cat => cat.slug === 'technology' || cat._id === 'technology');
                        if (defaultCat && selectedCategories.length === 0) {
                            selectedCategories.push(defaultCat);
                        }
                        renderCategories();
                    },
                    error: function (err) {
                        console.log('Failed to fetch categories, falling back to static options.', err);
                        const defaultCat = allCategories.find(cat => cat.slug === 'technology');
                        if (defaultCat && selectedCategories.length === 0) {
                            selectedCategories.push(defaultCat);
                        }
                        renderCategories();
                    }
                });

                // ── Blog Idea Generation & Outline Rendering ──
                let generatedIdeas = [];

                $('#aiConfigForm').on('submit', function (e) {
                    e.preventDefault();
                    const formData = $(this).serialize();

                    // Show spinner, hide placeholders and old results
                    $('#idea-placeholder').addClass('d-none');
                    $('#idea-list').addClass('d-none').empty();
                    $('#idea-spinner').removeClass('d-none').css('display', 'flex');
                    $('#outline-panel').addClass('d-none');
                    $('#content-placeholder').removeClass('d-none');

                    $.ajax({
                        url: '/ai/generate-blog-idea',
                        method: 'POST',
                        data: formData,
                        success: function (res) {
                            generatedIdeas = res.data?.ai_response?.blog_ideas || [];
                            renderBlogIdeas(generatedIdeas);
                        },
                        error: function (err) {
                            console.log('Form submission error:', err);
                            // Hide spinner, show placeholder again on error
                            $('#idea-spinner').addClass('d-none');
                            $('#idea-placeholder').removeClass('d-none');
                        }
                    });
                });

                // Idea card click — show outline in Content column
                $(document).on('click', '.idea-card', function () {
                    $('.idea-card').removeClass('active');
                    $(this).addClass('active');

                    const idx = parseInt($(this).data('index'));
                    const idea = generatedIdeas[idx];
                    if (!idea) return;

                    renderOutline(idea);
                });
            });

            function renderBlogIdeas(ideasArray) {
                const list = $('#idea-list');
                list.empty();

                ideasArray.forEach(function (idea, index) {
                    list.append(`
                        <div class="idea-card p-2 mb-2" data-index="${index}"
                             style="border:1px solid #e3e6f0; border-radius:6px; cursor:pointer; transition: all 0.18s; background:#fff;">
                            <div class="d-flex align-items-start">
                                <span style="font-size:0.7rem; font-weight:700; background:#eaecf4; color:#4e73df; border-radius:4px; padding:2px 7px; margin-right:8px; flex-shrink:0; margin-top:2px;">Idea ${index + 1}</span>
                                <p class="mb-0" style="font-size:0.82rem; font-weight:600; color:#2e3752; line-height:1.4;">${idea.title}</p>
                            </div>
                        </div>
                    `);
                });

                // Hide spinner, show list
                $('#idea-spinner').addClass('d-none');
                $('#idea-list').removeClass('d-none');

                // Auto-select first idea
                if (ideasArray.length > 0) {
                    $('.idea-card').first().addClass('active');
                    renderOutline(ideasArray[0]);
                }
            }

            function renderOutline(idea) {
                $('#outline-title').text(idea.title);
                $('#outline-intro').text(idea.outline.introduction);
                $('#outline-conclusion').text(idea.outline.conclusion);

                const bodyContainer = $('#outline-body-sections');
                bodyContainer.empty();

                idea.outline.body_sections.forEach(function (section) {
                    let pointsHtml = section.key_points.map(function (pt) {
                        return `<p class="outline-key-point mb-1">${pt}</p>`;
                    }).join('');

                    bodyContainer.append(`
                        <div class="mb-3">
                            <p class="outline-section-heading">${section.section_heading}</p>
                            ${pointsHtml}
                        </div>
                    `);
                });

                // Show outline, hide placeholder
                $('#content-placeholder').addClass('d-none');
                $('#outline-panel').removeClass('d-none');
            }
        </script>

</body>

</html>