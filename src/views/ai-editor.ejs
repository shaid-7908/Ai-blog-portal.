<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>SB Admin 2 - Dashboard</title>

    <!-- Custom fonts for this template-->
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link
        href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
        rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        /* Writing Tone Buttons */
        .tone-btn {
            background-color: #ffffff;
            border: 1px solid #d1d3e2;
            color: #5a5c69;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
        }

        .tone-btn:hover {
            border-color: #b7b9cc;
            background-color: #f8f9fc;
            color: #2e3752;
        }

        .tone-btn.active {
            background-color: #eaecf4 !important;
            border: 2px solid #4e73df !important;
            color: #4e73df !important;
        }

        /* Keywords Tag Input */
        .tags-input-container {
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }

        .tags-input-container:focus-within {
            border-color: #bac8f3 !important;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
        }

        .tag-chip {
            background-color: #eaecf4;
            color: #2e3752;
            padding: 0.3rem 0.55rem;
            border-radius: 4px;
            font-weight: 500;
            font-size: 0.8rem;
            border: 1px solid #dddfeb;
            display: inline-flex;
            align-items: center;
            margin-right: 4px;
            margin-bottom: 4px;
        }

        .tag-chip .remove-tag,
        .tag-chip .remove-category {
            color: #beccd6;
            margin-left: 6px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.9rem;
            line-height: 1;
            transition: color 0.15s;
        }

        .tag-chip .remove-tag:hover,
        .tag-chip .remove-category:hover {
            color: #e74a3b;
        }

        /* Custom Slider Range styling */
        #word-count-slider {
            -webkit-appearance: none;
            width: 100%;
            height: 6px;
            background: #eaecf4;
            border-radius: 5px;
            outline: none;
            margin: 10px 0;
        }

        #word-count-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #ffffff;
            border: 3px solid #4e73df;
            cursor: pointer;
            transition: transform 0.1s;
        }

        #word-count-slider::-webkit-slider-thumb:hover {
            transform: scale(1.25);
        }

        #word-count-slider::-moz-range-thumb {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #ffffff;
            border: 3px solid #4e73df;
            cursor: pointer;
            transition: transform 0.1s;
        }

        #word-count-slider::-moz-range-thumb:hover {
            transform: scale(1.25);
        }

        /* Select Customizations */
        .custom-select-premium {
            border-radius: 6px;
            border: 1px solid #d1d3e2;
            height: auto;
            padding: 0.6rem 0.75rem;
            font-size: 0.9rem;
        }

        .custom-select-premium:focus {
            border-color: #bac8f3;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
        }

        /* Idea Selector Tabs */
        .idea-tab {
            background: #f8f9fc;
            border: 1px solid #e3e6f0;
            border-radius: 6px;
            padding: 0.45rem 0.85rem;
            font-size: 0.78rem;
            font-weight: 600;
            color: #5a5c69;
            cursor: pointer;
            transition: all 0.18s;
            white-space: nowrap;
        }

        .idea-tab:hover {
            background: #eaecf4;
            border-color: #c0c4d6;
        }

        .idea-tab.active {
            background: #1a2a47;
            border-color: #1a2a47;
            color: #fff;
        }

        /* Outline Tree */
        .outline-section-heading {
            font-size: 0.82rem;
            font-weight: 700;
            color: #2e3752;
            margin-bottom: 4px;
        }

        .outline-key-point {
            font-size: 0.78rem;
            color: #5a5c69;
            padding-left: 14px;
            position: relative;
            line-height: 1.55;
        }

        .outline-key-point::before {
            content: '–';
            position: absolute;
            left: 0;
            color: #b7b9cc;
        }

        .outline-label {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            color: #b7b9cc;
            margin-bottom: 4px;
            margin-top: 10px;
        }

        .outline-intro-text,
        .outline-conclusion-text {
            font-size: 0.78rem;
            color: #5a5c69;
            line-height: 1.55;
            font-style: italic;
        }

        /* Content Editor */
        #ai-content-editor {
            width: 100%;
            min-height: 420px;
            border: 1px solid #d1d3e2;
            border-radius: 6px;
            padding: 0.75rem;
            font-size: 0.88rem;
            line-height: 1.7;
            color: #3d3d4e;
            resize: vertical;
            font-family: 'Nunito', sans-serif;
            transition: border-color 0.15s, box-shadow 0.15s;
            background: #fdfeff;
        }

        #ai-content-editor:focus {
            outline: none;
            border-color: #bac8f3;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.18);
        }

        #ai-content-editor:disabled {
            background: #f8f9fc;
            color: #b7b9cc;
        }

        .generate-btn {
            background: linear-gradient(135deg, #1a2a47 0%, #2e4882 100%);
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 0.55rem 1.4rem;
            font-size: 0.87rem;
            font-weight: 700;
            letter-spacing: 0.2px;
            cursor: pointer;
            transition: opacity 0.18s, transform 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .generate-btn:hover {
            opacity: 0.92;
            transform: translateY(-1px);
        }

        .generate-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        #outline-placeholder,
        #content-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 200px;
            color: #c0c4d6;
            text-align: center;
        }

        /* Idea Selection Cards */
        .idea-card:hover {
            border-color: #bac8f3 !important;
            background: #f8f9fc !important;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(78, 115, 223, 0.1);
        }

        .idea-card.active {
            border-color: #4e73df !important;
            background: #f0f4ff !important;
            box-shadow: 0 2px 10px rgba(78, 115, 223, 0.15);
        }

        .idea-card.active p {
            color: #1a2a47 !important;
        }
    </style>
</head>

