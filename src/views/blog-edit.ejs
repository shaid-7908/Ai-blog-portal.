<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>SB Admin 2 - <%= pageTitle %></title>
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        #imagePreview     { max-height:220px; object-fit:cover; border-radius:8px; }
        #currentImageWrap { max-height:180px; object-fit:cover; border-radius:8px; }
        .ql-editor        { min-height:280px; font-size:1rem; }
        .ql-toolbar       { background:#f8f9fc; border-radius:4px 4px 0 0; }
        .ql-container     { border-radius:0 0 4px 4px; }
        .char-count       { font-size:.78rem; }
    </style>
</head>
<body id="page-top">
<div id="wrapper">
    <%- include('components/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            <%- include('components/topbar') %>
            <div class="container-fluid">

                <!-- Breadcrumb -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-1">
                                <li class="breadcrumb-item"><a href="/blog-management">Blog Management</a></li>
                                <li class="breadcrumb-item active" id="breadcrumbTitle">Edit Blog</li>
                            </ol>
                        </nav>
                        <h1 class="h3 mb-0 text-gray-800">Edit Blog Post</h1>
                    </div>
                    <div class="d-flex" style="gap:8px;">
                        <a id="viewBtn" href="#" class="btn btn-info btn-sm"><i class="fas fa-eye mr-1"></i>View Post</a>
                        <a href="/blog-management" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i> Back to List</a>
                    </div>
                </div>

                <!-- Loading spinner -->
                <div id="loadingCard" class="text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
                    <p class="mt-3 text-gray-600">Loading blog post…</p>
                </div>

                <div id="alertContainer"></div>

                <!-- Form (hidden until data loaded) -->
                <form id="editBlogForm" enctype="multipart/form-data" class="d-none">
                    <div class="row">

                        <!-- Left: main content -->
                        <div class="col-lg-8">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Post Details</h6></div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label class="font-weight-bold">Title <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="blogTitle" name="title" placeholder="Blog title…" required minlength="3">
                                    </div>
                                    <div class="form-group">
                                        <label class="font-weight-bold">Excerpt</label>
                                        <textarea class="form-control" id="blogExcerpt" name="excerpt" rows="2" placeholder="Short summary…" maxlength="300"></textarea>
                                        <small class="form-text char-count text-muted"><span id="excerptCount">0</span>/300</small>
                                    </div>
                                    <div class="form-group mb-0">
                                        <label class="font-weight-bold">Content <span class="text-danger">*</span></label>
                                        <div id="quillEditor"></div>
                                        <input type="hidden" id="blogContent" name="content">
                                    </div>
                                </div>
                            </div>

                            <!-- SEO -->
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">SEO Settings</h6></div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label class="font-weight-bold">SEO Title</label>
                                        <input type="text" class="form-control" id="seoTitle" name="seoTitle" placeholder="Override in search results…">
                                    </div>
                                    <div class="form-group mb-0">
                                        <label class="font-weight-bold">SEO Description</label>
                                        <textarea class="form-control" id="seoDescription" name="seoDescription" rows="2" placeholder="Meta description…" maxlength="160"></textarea>
                                        <small class="form-text char-count text-muted"><span id="seoDescCount">0</span>/160</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right: settings -->
                        <div class="col-lg-4">

                            <!-- Publish -->
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Publish</h6></div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label class="font-weight-bold">Status</label>
                                        <select class="form-control" id="blogStatus" name="status">
                                            <option value="Draft">Draft</option>
                                            <option value="Published">Published</option>
                                            <option value="Pending Review">Pending Review</option>
                                            <option value="Archived">Archived</option>
                                            <option value="Rejected">Rejected</option>
                                        </select>
                                    </div>
                                    <hr>
                                    <button type="submit" class="btn btn-warning btn-block" id="submitBtn">
                                        <span id="submitBtnText"><i class="fas fa-save mr-1"></i>Save Changes</span>
                                        <span id="submitBtnSpinner" class="d-none"><i class="fas fa-spinner fa-spin mr-1"></i>Saving…</span>
                                    </button>
                                    <a href="/blog-management" class="btn btn-secondary btn-block mt-2">Cancel</a>
                                </div>
                            </div>

                            <!-- Categories -->
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Categories</h6></div>
                                <div class="card-body">
                                    <label class="font-weight-bold">Select Categories</label>
                                    <select class="form-control" id="blogCategories" name="categories" multiple></select>
                                    <small class="form-text text-muted">Hold Ctrl / Cmd to select multiple.</small>
                                </div>
                            </div>

                            <!-- Feature Image -->
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Feature Image</h6></div>
                                <div class="card-body text-center">
                                    <!-- Current image (from saved blog) -->
                                    <div id="currentImageWrap" class="mb-2 d-none">
                                        <p class="small font-weight-bold text-muted mb-1">Current Image</p>
                                        <img id="currentImage" src="" alt="Current feature" class="img-fluid w-100 currentImageWrap" style="max-height:140px;object-fit:cover;border-radius:6px;">
                                    </div>
                                    <!-- New image preview -->
                                    <div id="imagePreviewWrapper" class="mb-2 d-none">
                                        <p class="small font-weight-bold text-success mb-1"><i class="fas fa-check-circle mr-1"></i>New Image Selected</p>
                                        <img id="imagePreview" src="" alt="New preview" class="img-fluid w-100" style="max-height:140px;object-fit:cover;border-radius:6px;">
                                    </div>
                                    <input type="file" class="form-control-file" id="featureImage" name="image" accept="image/*">
                                    <small class="form-text text-muted">Upload a new image to replace the current one. Max 10 MB.</small>
                                </div>
                            </div>

                        </div>
                    </div>
                </form>

            </div>
        </div>
        <footer class="sticky-footer bg-white">
            <div class="container my-auto">
                <div class="copyright text-center my-auto"><span>Copyright &copy; Your Website 2021</span></div>
            </div>
        </footer>
    </div>
</div>

<a class="scroll-to-top rounded" href="#page-top"><i class="fas fa-angle-up"></i></a>

<!-- Logout Modal -->
<div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Ready to Leave?</h5>
                <button class="close" type="button" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                <a class="btn btn-primary" href="/logout">Logout</a>
            </div>
        </div>
    </div>
</div>

<%- include('components/commonscript') %>

<!-- Quill -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>

<script>
const BLOG_ID = '<%= blogId %>';

$(document).ready(function () {

    // ── Init Quill ────────────────────────────────────────────────────────────
    const quill = new Quill('#quillEditor', {
        theme: 'snow',
        placeholder: 'Write your blog content here…',
        modules: {
            toolbar: [
                [{ header: [1,2,3,4,false] }],
                ['bold','italic','underline','strike'],
                [{ list:'ordered' },{ list:'bullet' }],
                [{ color:[] },{ background:[] }],
                ['link','image','blockquote','code-block'],
                ['clean']
            ]
        }
    });

    // ── Load Categories ───────────────────────────────────────────────────────
    let allCategories = [];
    $.get('/api/v1/blog-category/get-all?limit=100', function (res) {
        if (res.success && res.data) {
            allCategories = res.data.docs;
            allCategories.forEach(function (cat) {
                $('#blogCategories').append(new Option(cat.name, cat._id));
            });
        }
        // Load blog after categories are ready so we can pre-select
        loadBlog();
    });

    // ── Load Blog ─────────────────────────────────────────────────────────────
    function loadBlog() {
        $.ajax({
            url: `/api/v1/blog/get-by-id/${BLOG_ID}`,
            method: 'GET',
            success: function (res) {
                if (res.success && res.data) {
                    populateForm(res.data);
                } else {
                    showAlert('Blog not found.', 'warning');
                    $('#loadingCard').addClass('d-none');
                }
            },
            error: function () {
                $('#loadingCard').addClass('d-none');
                showAlert('Failed to load blog data.', 'danger');
            }
        });
    }

    function populateForm(blog) {
        $('#loadingCard').addClass('d-none');
        $('#editBlogForm').removeClass('d-none');

        const title = blog.title || '';
        $('#breadcrumbTitle').text(title.length > 40 ? title.substring(0,40)+'…' : title);
        $('#viewBtn').attr('href', `/blog-management/view/${blog._id}`);

        $('#blogTitle').val(blog.title || '');
        $('#blogExcerpt').val(blog.excerpt || '');
        $('#excerptCount').text((blog.excerpt || '').length);

        // Quill content
        quill.root.innerHTML = blog.content || '';

        // Status
        $('#blogStatus').val(blog.status || 'Draft');

        // SEO
        $('#seoTitle').val(blog.seoTitle || '');
        $('#seoDescription').val(blog.seoDescription || '');
        $('#seoDescCount').text((blog.seoDescription || '').length);

        // Feature image
        if (blog.featureImage) {
            $('#currentImage').attr('src', blog.featureImage);
            $('#currentImageWrap').removeClass('d-none');
        }

        // Pre-select categories
        if (blog.categories && blog.categories.length) {
            const selectedIds = blog.categories.map(c => c.categoryId.toString());
            $('#blogCategories option').each(function () {
                if (selectedIds.includes($(this).val())) {
                    $(this).prop('selected', true);
                }
            });
        }
    }

    // ── Image preview ─────────────────────────────────────────────────────────
    $('#featureImage').on('change', function () {
        const file = this.files[0];
        if (file) {
            $('#imagePreview').attr('src', URL.createObjectURL(file));
            $('#imagePreviewWrapper').removeClass('d-none');
        }
    });

    // ── Char counters ─────────────────────────────────────────────────────────
    $('#blogExcerpt').on('input', function () { $('#excerptCount').text($(this).val().length); });
    $('#seoDescription').on('input', function () { $('#seoDescCount').text($(this).val().length); });

    // ── Submit ────────────────────────────────────────────────────────────────
    $('#editBlogForm').on('submit', function (e) {
        e.preventDefault();

        const content = quill.root.innerHTML.trim();
        if (!content || content === '<p><br></p>') {
            showAlert('Content is required.', 'danger'); return;
        }
        $('#blogContent').val(content);

        const title = $('#blogTitle').val().trim();
        if (!title) { showAlert('Title is required.', 'danger'); return; }

        const formData = new FormData(this);

        // Rebuild categories
        formData.delete('categories');
        $('#blogCategories option:selected').each(function () {
            formData.append('categories', $(this).val());
        });

        $('#submitBtnText').addClass('d-none');
        $('#submitBtnSpinner').removeClass('d-none');

        $.ajax({
            url: `/api/v1/blog/update/${BLOG_ID}`,
            method: 'PUT',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                if (res.success) {
                    showAlert('Blog post updated successfully! <a href="/blog-management/view/' + BLOG_ID + '" class="alert-link">View Post</a>', 'success');
                    $('html, body').animate({ scrollTop: 0 }, 300);
                } else {
                    showAlert(res.message || 'Update failed.', 'danger');
                }
            },
            error: function (xhr) {
                const msg = xhr.responseJSON ? (xhr.responseJSON.message || JSON.stringify(xhr.responseJSON.errors)) : 'An error occurred.';
                showAlert(msg, 'danger');
            },
            complete: function () {
                $('#submitBtnText').removeClass('d-none');
                $('#submitBtnSpinner').addClass('d-none');
            }
        });
    });

    function showAlert(msg, type) {
        $('#alertContainer').html(`<div class="alert alert-${type} alert-dismissible fade show">
            ${msg}<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
        </div>`);
        $('html, body').animate({ scrollTop: 0 }, 300);
    }
});
</script>
</body>
</html>
