<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>SB Admin 2 - <%= pageTitle %></title>
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="/css/sb-admin-2.min.css" rel="stylesheet">
    <style>
        .badge-draft          { background:#858796; color:#fff; }
        .badge-published      { background:#1cc88a; color:#fff; }
        .badge-archived       { background:#36b9cc; color:#fff; }
        .badge-pending-review { background:#f6c23e; color:#333; }
        .badge-rejected       { background:#e74a3b; color:#fff; }
        .blog-feature-img { width:100%; max-height:350px; object-fit:cover; border-radius:8px; }
        .blog-content-body img { max-width:100%; border-radius:4px; margin:8px 0; }
        .meta-label { font-size:.72rem; text-transform:uppercase; letter-spacing:.05em; color:#858796; font-weight:700; }
        .meta-value { font-size:.95rem; color:#3a3b45; }
        .seo-box { background:#f8f9fc; border:1px solid #e3e6f0; border-radius:8px; padding:1rem 1.25rem; }
        #loading-overlay { display:none; }
    </style>
</head>
<body id="page-top">
<div id="wrapper">
    <%- include('components/sidebar') %>
    <div id="content-wrapper" class="d-flex flex-column">
        <div id="content">
            <%- include('components/topbar') %>
            <div class="container-fluid">

                <!-- Heading -->
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <div>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-1">
                                <li class="breadcrumb-item"><a href="/blog-management">Blog Management</a></li>
                                <li class="breadcrumb-item active" id="breadcrumbTitle">View Blog</li>
                            </ol>
                        </nav>
                        <h1 class="h3 mb-0 text-gray-800">Blog Post Details</h1>
                    </div>
                    <div class="d-flex gap-2" style="gap:8px;">
                        <a href="/blog-management" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left mr-1"></i> Back</a>
                        <a id="editBtn" href="#" class="btn btn-warning btn-sm"><i class="fas fa-edit mr-1"></i>Edit Post</a>
                    </div>
                </div>

                <div id="alertContainer"></div>

                <!-- Loading -->
                <div id="loadingCard" class="text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
                    <p class="mt-3 text-gray-600">Loading blog post…</p>
                </div>

                <!-- Content revealed after load -->
                <div id="blogContent" class="d-none">
                    <div class="row">
                        <!-- Main content column -->
                        <div class="col-lg-8">
                            <!-- Feature Image -->
                            <div id="featureImageWrapper" class="mb-4 d-none">
                                <img id="featureImage" src="" alt="Feature Image" class="blog-feature-img shadow">
                            </div>

                            <!-- Title + Meta -->
                            <div class="card shadow mb-4">
                                <div class="card-body">
                                    <h2 id="blogTitle" class="h4 font-weight-bold text-gray-900 mb-2"></h2>
                                    <p id="blogExcerpt" class="text-gray-600 mb-3"></p>
                                    <hr>
                                    <div class="blog-content-body" id="blogBody"></div>
                                </div>
                            </div>

                            <!-- SEO -->
                            <div class="card shadow mb-4" id="seoCard">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">SEO Information</h6></div>
                                <div class="card-body">
                                    <div class="seo-box mb-3">
                                        <p class="meta-label mb-1">SEO Title</p>
                                        <p id="seoTitle" class="meta-value mb-0">—</p>
                                    </div>
                                    <div class="seo-box">
                                        <p class="meta-label mb-1">SEO Description</p>
                                        <p id="seoDescription" class="meta-value mb-0">—</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right sidebar: meta -->
                        <div class="col-lg-4">
                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Post Details</h6></div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <p class="meta-label mb-1">Status</p>
                                        <div id="blogStatus"></div>
                                    </div>
                                    <div class="mb-3">
                                        <p class="meta-label mb-1">Slug</p>
                                        <code id="blogSlug" class="text-primary"></code>
                                    </div>
                                    <div class="mb-3">
                                        <p class="meta-label mb-1">Author</p>
                                        <p id="blogAuthor" class="meta-value mb-0">—</p>
                                    </div>
                                    <div class="mb-3">
                                        <p class="meta-label mb-1">Created</p>
                                        <p id="blogCreatedAt" class="meta-value mb-0">—</p>
                                    </div>
                                    <div class="mb-0">
                                        <p class="meta-label mb-1">Updated</p>
                                        <p id="blogUpdatedAt" class="meta-value mb-0">—</p>
                                    </div>
                                </div>
                            </div>

                            <div class="card shadow mb-4">
                                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Categories</h6></div>
                                <div class="card-body" id="blogCategories">
                                    <span class="text-muted">—</span>
                                </div>
                            </div>

                            <div class="card shadow mb-4">
                                <div class="card-body text-center">
                                    <a id="editBtnBottom" href="#" class="btn btn-warning btn-block mb-2"><i class="fas fa-edit mr-1"></i>Edit This Post</a>
                                    <button class="btn btn-danger btn-block" id="deletePostBtn"><i class="fas fa-trash mr-1"></i>Delete Post</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Delete Modal -->
                <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title"><i class="fas fa-trash mr-2"></i>Delete Blog</h5>
                                <button class="close text-white" type="button" data-dismiss="modal"><span>&times;</span></button>
                            </div>
                            <div class="modal-body">
                                Are you sure you want to delete this blog post? This action is irreversible.
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                                    <span id="deleteBtnText"><i class="fas fa-trash mr-1"></i>Yes, Delete</span>
                                    <span id="deleteBtnSpinner" class="d-none"><i class="fas fa-spinner fa-spin mr-1"></i>Deleting…</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <footer class="sticky-footer bg-white">
            <div class="container my-auto">
                <div class="copyright text-center my-auto"><span>Copyright &copy; Your Website 2021</span></div>
            </div>
        </footer>
    </div>
</div>

<a class="scroll-to-top rounded" href="#page-top"><i class="fas fa-angle-up"></i></a>

<!-- Logout Modal -->
<div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Ready to Leave?</h5>
                <button class="close" type="button" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                <a class="btn btn-primary" href="/logout">Logout</a>
            </div>
        </div>
    </div>
</div>

<%- include('components/commonscript') %>
<script>
const BLOG_ID = '<%= blogId %>';

$(document).ready(function () {

    const statusMap = {
        'Draft':          'badge-draft',
        'Published':      'badge-published',
        'Archived':       'badge-archived',
        'Pending Review': 'badge-pending-review',
        'Rejected':       'badge-rejected'
    };

    function fmtDate(d) {
        return d ? new Date(d).toLocaleDateString('en-US',{ year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
    }

    function showAlert(msg, type) {
        $('#alertContainer').html(`<div class="alert alert-${type} alert-dismissible fade show">
            ${msg}<button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
        </div>`);
    }

    // ── Load Blog ─────────────────────────────────────────────────────────────
    $.ajax({
        url: `/api/v1/blog/get-by-id/${BLOG_ID}`,
        method: 'GET',
        success: function (res) {
            if (res.success && res.data) {
                renderBlog(res.data);
            } else {
                showAlert('Blog not found.', 'warning');
                $('#loadingCard').addClass('d-none');
            }
        },
        error: function () {
            $('#loadingCard').addClass('d-none');
            showAlert('Failed to load blog.', 'danger');
        }
    });

    function renderBlog(blog) {
        $('#loadingCard').addClass('d-none');
        $('#blogContent').removeClass('d-none');

        const editUrl = `/blog-management/edit/${blog._id}`;
        $('#editBtn').attr('href', editUrl);
        $('#editBtnBottom').attr('href', editUrl);
        $('#breadcrumbTitle').text(blog.title.length > 40 ? blog.title.substring(0,40)+'…' : blog.title);

        // Feature image
        if (blog.featureImage) {
            $('#featureImage').attr('src', blog.featureImage);
            $('#featureImageWrapper').removeClass('d-none');
        }

        $('#blogTitle').text(blog.title || '—');
        $('#blogExcerpt').text(blog.excerpt || '');
        $('#blogBody').html(blog.content || '<p class="text-muted">No content.</p>');
        $('#blogSlug').text(blog.slug || '—');
        $('#blogAuthor').text(blog.author ? `${blog.author.firstName} ${blog.author.lastName}` : '—');
        $('#blogCreatedAt').text(fmtDate(blog.createdAt));
        $('#blogUpdatedAt').text(fmtDate(blog.updatedAt));

        const cls = statusMap[blog.status] || 'badge-secondary';
        $('#blogStatus').html(`<span class="badge ${cls} px-2 py-1">${blog.status || '—'}</span>`);

        if (blog.categories && blog.categories.length) {
            const badges = blog.categories.map(c => `<span class="badge badge-info mr-1 mb-1">${c.name}</span>`).join('');
            $('#blogCategories').html(badges);
        }

        $('#seoTitle').text(blog.seoTitle || 'Not set');
        $('#seoDescription').text(blog.seoDescription || 'Not set');
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    $('#deletePostBtn').on('click', () => $('#deleteModal').modal('show'));

    $('#confirmDeleteBtn').on('click', function () {
        $('#deleteBtnText').addClass('d-none');
        $('#deleteBtnSpinner').removeClass('d-none');

        $.ajax({
            url: `/api/v1/blog/delete/${BLOG_ID}`,
            method: 'DELETE',
            success: () => { window.location.href = '/blog-management?deleted=1'; },
            error: (xhr) => {
                $('#deleteModal').modal('hide');
                showAlert(xhr.responseJSON ? xhr.responseJSON.message : 'Delete failed.', 'danger');
            },
            complete: () => {
                $('#deleteBtnText').removeClass('d-none');
                $('#deleteBtnSpinner').addClass('d-none');
            }
        });
    });
});
</script>
</body>
</html>
